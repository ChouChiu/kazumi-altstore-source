{
  "name": "kazumi-altstore-source",
  "version": "0.1.0",
  "description": "AltStore source for Kazumi",
  "keywords": [
    "altstore",
    "kazumi",
    "manga",
    "tachiyomi"
  ],
  "homepage": "https://github.com/WingChunWong/Kazumi-AltStore-Source#readme",
  "bugs": "https://github.com/WingChunWong/Kazumi-AltStore-Source/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WingChunWong/Kazumi-AltStore-Source.git"
  },
  "license": "MIT",
  "author": "maxchang3",
  "type": "module",
  "scripts": {
    "generate": "bun run src/index.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write .",
    "prepare": "simple-git-hooks",
    "typecheck": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "bun install --frozen-lockfile --ignore-scripts && bunx lint-staged"
  },
  "lint-staged": {
    "*": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@maxchang/biome-config": "^0.1.8",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.8"
}
